{% extends "base.jinja2" %}

{% block head %}
  <script src="{{ url_for('static', filename='js/d3.min.js') }}"></script>
  <link href="{{ url_for('static', filename='css/yasgui.min.css') }}" rel="stylesheet" type="text/css" />
  <script src="{{ url_for('static', filename='js/yasgui.min.js') }}"></script>
  <link href="{{ url_for('static', filename='css/detrusty-plan.css') }}" rel="stylesheet" type="text/css" />
  <script src="{{ url_for('static', filename='js/detrusty-plan.js') }}"></script>
{% endblock %}

{% block content %}
  <div id="federation-bar">
    <label for="federation-select">Federation:</label>
    <select id="federation-select">
      <option value="">All federations</option>
    </select>
  </div>
  <div id="yasqe" data-endpoint="{{ url_for('query_plan') }}" data-federations-endpoint="{{ url_for('federations') }}"></div>
  <div id="plan-error"></div>
  <div id="plan-container">
    <div id="canvas-wrapper">
      <div id="canvas"></div>
      <div id="canvas-toolbar"></div>
    </div>
    <div id="details"></div>
    <div id="plan-clear"></div>
  </div>
  <div id="plan-tooltip"></div>
{% endblock %}
